# این فایل را کپی کن به .env.production (کنار همین پوشه frontend) و مقدار
# واقعی را بگذار، بعد فرانت را build بگیر (npm run build).
# اگر این مقدار ست نشود، فرانت پس از دیپلوی سعی می‌کند به 127.0.0.1:8000 وصل شود
# که از سرور واقعی در دسترس نیست و باعث خطای "خطا در دریافت آگهی‌ها" می‌شود.

VITE_API_URL=https://api.yourdomain.com/api
