{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "incremental": true,

    "target": "ES2022",
    "lib": [
      "ES2022"
    ],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,

    "strict": true,
    "noEmit": true
  },

  "include": [
    "vite.config.ts"
  ]
}