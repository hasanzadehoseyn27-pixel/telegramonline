# این فایل فقط نمونه است — مقادیر واقعی را در فایل .env (که در .gitignore است)
# قرار بده، هرگز مقادیر واقعی را در .env.example یا هیچ فایل کامیت‌شده‌ای قرار نده.

TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_GROUP=-100xxxxxxxxxx
DATABASE_PATH=data/telegramonline.sqlite3
EXPORT_PATH=data/group_export_BAZARBOZORGEKHODROIRAN.txt

# دامنه‌های واقعی فرانت که اجازه دارن به این API وصل بشن (با کاما جدا کن)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
